// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// User model for authentication
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("agent")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  promos        Promo[]
  layouts       Layout[]
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

// NextAuth Account model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// NextAuth VerificationToken model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Promo model
model Promo {
  id              String   @id @default(cuid())
  destino         String
  hotel           String
  dataFormatada   String
  valor           String
  parcelas        Int      @default(15)
  comCafe         Boolean  @default(false)
  semCafe         Boolean  @default(false)
  meiaPensao      Boolean  @default(false)
  pensaoCompleta  Boolean  @default(false)
  allInclusive    Boolean  @default(false)
  numeroDeNoites  String
  sp              Boolean  @default(false)
  cg              Boolean  @default(false)
  aereo           Boolean  @default(false)
  sitePublished   Boolean  @default(false)
  siteSection     String?
  siteSlug        String?  @unique
  siteImage       String?
  siteDescription String?  @db.Text
  siteInclusions  String[] @default([])
  siteDepartures  String[] @default([])
  googleBusinessPostName String? @db.Text
  instagramPostId String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])

  @@map("promos")
}

model GoogleBusinessConnection {
  id            String   @id @default(cuid())
  refreshToken  String   @db.Text
  accountName   String?  @db.Text
  locationName  String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("google_business_connections")
}

model InstagramConnection {
  id              String    @id @default(cuid())
  accessToken     String    @db.Text
  igUserId        String
  pageName        String?
  tokenExpiresAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("instagram_connections")
}

// Lead model for capturing interested customers
model Lead {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String?
  source          String   @default("website") // website, popup, footer, whatsapp
  destino         String?  // Destination they were interested in
  hotel           String?  // Hotel they were interested in
  promoDetails    String?  // JSON with promo details
  status          String   @default("new") // new, contacted, converted, lost
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("leads")
}

// Layout/Template model
model Layout {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("png") // png, svg, custom
  format      String   @default("story") // story, feed
  isDefault   Boolean  @default(false)

  // Template image URL (local path or external URL)
  imageUrl    String?

  // Element configurations as JSON (text elements)
  elements    Json

  // Image areas for photos (JSON array of ImageArea objects)
  imageAreas  Json?

  // Color configurations as JSON
  colors      Json

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@map("layouts")
}
